+
+def _powershell_quote(value):
+    return "'" + str(value).replace("'", "''") + "'"
+
+def _copy_tree_with_powershell(rctx, src_dir):
+    command = "; ".join([
+        "$ErrorActionPreference = 'Stop'",
+        "Copy-Item -Path {src} -Destination {dst} -Recurse -Force".format(
+            src = _powershell_quote(str(src_dir).replace("\\", "/") + "/*"),
+            dst = _powershell_quote(str(rctx.path(".")).replace("\\", "/")),
+        ),
+    ])
+    result = rctx.execute([
+        "powershell.exe",
+        "-NoProfile",
+        "-NonInteractive",
+        "-ExecutionPolicy",
+        "Bypass",
+        "-Command",
+        command,
+    ])
+    if result.return_code:
+        fail("Failed to copy LLVM subproject tree: " + result.stderr)
 
